@model List<VulnerableApp.Models.User>

<h2>Búsqueda de Usuarios</h2>

<form asp-action="Index" method="get">
    <input type="text" name="search" placeholder="Nombre de usuario..." />
    <button type="submit">Buscar</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Usuario</th>
            <th>Email</th>
            <th>Balance</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Username</td>
                <td>@user.Email</td>
                <td>$@user.Balance</td>
            </tr>
        }
    </tbody>
</table>
